# Required
GROQ_API_KEY=gsk_your_groq_api_key_here

# Redis — use DB 1 to coexist with judge-service (DB 0)
# For standalone dev (local Redis):
REDIS_URL=redis://localhost:6379/1
# For docker-compose: overridden automatically → redis://ai-redis:6379/1

# Judge service (needed to execute generated test cases)
JUDGE_SERVICE_URL=http://localhost:8001

# Groq models (defaults are already optimal — change only if needed)
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile
GROQ_MODEL_CODE=llama-3.1-8b-instant

# Seconds to sleep before each Groq API call (free-tier rate-limit guard)
GROQ_RPM_SLEEP=5.0

# Optional: protect this service's endpoints with an API key
AI_API_KEY=

# Redis TTL for job data (seconds) — default 24h
JOB_TTL_SECONDS=86400
