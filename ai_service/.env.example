# ai_service/.env.example
# Copy to .env and fill in your values

GEMINI_API_KEY=your_gemini_api_key_here
RABBITMQ_URL=
RABBITMQ_QUEUE=problem_generation
MONGODB_URI==

# Gemini free-tier rate limits (adjust if you upgrade)
# Flash 1.5: 15 RPM, 1M TPM, 1500 RPD
GEMINI_MODEL=gemini-1.5-flash
GEMINI_RPM_LIMIT=15        # requests per minute
GEMINI_RPD_LIMIT=1500      # requests per day
