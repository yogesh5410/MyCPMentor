# ── Judge Service environment ──────────────────────────────────────────────────
# Copy this file to .env and fill in any overrides.
# docker-compose injects these into every service container.

# Redis broker & result backend
REDIS_URL=redis://redis:6379/0

# Docker image used to spin up sandbox containers
DOCKER_SANDBOX_IMAGE=judge-sandbox:latest

# Hard caps (requests exceeding these are clamped silently)
MAX_TIME_LIMIT=10
MAX_MEMORY_LIMIT=512

# Defaults applied when a submission omits these fields
DEFAULT_TIME_LIMIT=5
DEFAULT_MEMORY_LIMIT=256

# Extra seconds added to subprocess wall-clock timeout
# (accounts for container startup/teardown overhead)
CONTAINER_OVERHEAD=10

# Optional: shared secret for internal service-to-service calls
# Leave empty to disable API key enforcement.
JUDGE_API_KEY=
